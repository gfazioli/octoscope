# Built binary (go build ./... produces it at the module root)
/octoscope
/octoscope-*

# Goreleaser output (added in v0.2+)
/dist/

# vhs rendered output (tapes/*.tape are committed; tapes/out/ is
# regenerable via `make tapes` and never lands in git).
/tapes/out/

# Go test coverage
coverage.out
coverage.html

# Editors
.idea/
.vscode/
*.swp
.DS_Store

# Local env overrides
.env
.env.local

# Internal roadmap — kept local, not shared with the public repo
ROADMAP.md

# Claude Code per-maintainer config — slash commands, settings,
# permission allowlists. Everything under .claude/ is intentionally
# local: the slash commands here (octoscope-release, octoscope-smoke,
# octoscope-ph-thread) wrap the maintainer's release / verification
# workflow and aren't meaningful to a fork. Same idea as
# ROADMAP.md above — internal planning vs consumer-facing repo.
.claude/

# Advisor implementation plans (improve skill) — local planning record,
# not shared with the public repo (same idea as ROADMAP.md / .claude/).
plans/

